# Lightweight image for Chat UI (no CUDA/ML dependencies needed)
FROM python:3.10-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    "gradio>=6.0.0" \
    requests \
    plotly

# Copy only chat UI file
COPY chat_ui.py .

# Expose Gradio port
EXPOSE 7860

# Launch chat UI
CMD ["python", "chat_ui.py"]
